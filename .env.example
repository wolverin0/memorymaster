# =============================================================================
# MemoryMaster Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables are optional — sensible defaults are built in.

# ---------------------------------------------------------------------------
# Core settings
# ---------------------------------------------------------------------------

# Path to the SQLite database file (default: memorymaster.db in working dir)
MEMORYMASTER_DEFAULT_DB=memorymaster.db

# Workspace root for staleness detection and file watching
MEMORYMASTER_WORKSPACE=.

# JSON config file path (overrides individual env vars below)
# MEMORYMASTER_CONFIG_FILE=config.json

# ---------------------------------------------------------------------------
# External services
# ---------------------------------------------------------------------------

# Ollama LLM endpoint (used by extractor, resolver, entity graph, steward)
OLLAMA_URL=http://localhost:11434

# Qdrant vector store endpoint (for semantic search and sync)
QDRANT_URL=http://localhost:6333

# Gemini API key (for Gemini embeddings / steward LLM)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# LLM model overrides
# ---------------------------------------------------------------------------

# Model for claim extraction (default: llama3.2)
# EXTRACTOR_LLM_MODEL=llama3.2

# Model for conflict resolution (default: llama3.2)
# RESOLVER_LLM_MODEL=llama3.2

# Model for entity extraction (default: llama3.2)
# ENTITY_LLM_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Steward / LLM API keys
# ---------------------------------------------------------------------------

# Comma-separated API keys for round-robin rotation
# MEMORYMASTER_API_KEYS=key1,key2,key3

# Single API key fallback
# MEMORYMASTER_API_KEY=your-api-key

# ---------------------------------------------------------------------------
# Retrieval ranking weights
# ---------------------------------------------------------------------------

# Hybrid mode with vector: lexical,confidence,freshness,vector
# MEMORYMASTER_RETRIEVAL_WEIGHTS=0.45,0.30,0.15,0.10

# Hybrid mode without vector: lexical,confidence,freshness
# MEMORYMASTER_RETRIEVAL_WEIGHTS_NO_VECTOR=0.55,0.30,0.15

# Lexical sub-score: recall,precision,phrase,prefix
# MEMORYMASTER_LEXICAL_WEIGHTS=0.55,0.15,0.25,0.05

# ---------------------------------------------------------------------------
# Decay and lifecycle tuning
# ---------------------------------------------------------------------------

# Freshness half-life hours by volatility: low,medium,high
# MEMORYMASTER_FRESHNESS_HALFLIFE=168.0,72.0,24.0

# Revalidation cadence hours by volatility: low,medium,high
# MEMORYMASTER_CADENCE_HOURS=168.0,72.0,24.0

# Daily decay rates by volatility: low,medium,high
# MEMORYMASTER_DECAY_RATES=0.01,0.03,0.06

# ---------------------------------------------------------------------------
# Thresholds
# ---------------------------------------------------------------------------

# Minimum score for a claim to pass validation (default: 0.58)
# MEMORYMASTER_VALIDATION_THRESHOLD=0.58

# Confidence below which a claim transitions to stale (default: 0.35)
# MEMORYMASTER_STALE_THRESHOLD=0.35

# Score margin for conflict detection (default: 0.08)
# MEMORYMASTER_CONFLICT_MARGIN=0.08

# Score bonus applied to pinned claims during ranking (default: 0.03)
# MEMORYMASTER_PINNED_BONUS=0.03

# ---------------------------------------------------------------------------
# Access control
# ---------------------------------------------------------------------------

# Path to roles config JSON for RBAC
# MEMORYMASTER_ROLES_CONFIG=roles.json

# Per-agent role overrides: MEMORYMASTER_ROLE_<AGENT>=<role>
# MEMORYMASTER_ROLE_CLAUDE=admin
# MEMORYMASTER_ROLE_CODEX=reader

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Set to "1" to allow --allow-sensitive flag (disabled by default)
# MEMORYMASTER_ALLOW_SENSITIVE_BYPASS=0
