{"id":"revalidation_stales_when_citations_removed","description":"Cadence revalidation should stale a previously confirmed claim when evidence is removed.","tags":["adversarial","cadence","staleness"],"steps":[{"action":"ingest","text":"Server IP is 10.9.0.7","subject":"server","predicate":"ip_address","object_value":"10.9.0.7","volatility":"high","sources":["session://chat|turn-adversarial-3|initial evidence"]},{"action":"run_cycle","policy_mode":"legacy","min_citations":1,"min_score":0.5},{"action":"sql","sql":"DELETE FROM citations WHERE claim_id = (SELECT id FROM claims WHERE subject='server' AND predicate='ip_address' AND object_value='10.9.0.7' ORDER BY id DESC LIMIT 1)"},{"action":"sql","sql":"UPDATE claims SET last_validated_at='2025-01-01T00:00:00+00:00', updated_at='2025-01-01T00:00:00+00:00' WHERE subject='server' AND predicate='ip_address' AND object_value='10.9.0.7'"},{"action":"run_cycle","policy_mode":"cadence","policy_limit":50,"min_citations":1,"min_score":0.5}],"expectations":{"cycle_checks":[{"path":"policy.due","min":1},{"path":"validator.revalidation_processed","min":1}],"claims":[{"subject":"server","predicate":"ip_address","object_value":"10.9.0.7","status":"stale"}]}}
